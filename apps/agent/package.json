{
  "name": "agent",
  "version": "2.0.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "ws": "^8.20.0"
  },
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "setup": "bun run src/main.ts setup",
    "build:windows": "bun build --compile --target=bun-windows-x64 --icon=./public/icon.png ./src/main.ts --outfile dist/backupr-agent.exe",
    "build:linux": "bun build --compile --target=bun-linux-x64 --icon=./public/icon.png ./src/main.ts --outfile dist/backupr-agent"
  }
}
